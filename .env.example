# Required configuration
# Obtain your bot token from @BotFather on Telegram 
TELEGRAM_BOT_TOKEN=123456:replace-me
# Comma-separated list of user IDs that are authorized to use the bot
# Tip: Use @userinfobot on Telegram to find your user ID
TELEGRAM_ALLOWED_USER_IDS=123456789

# Optional configuration with sensible defaults
# Path to the Pi CLI executable - default 'pi' assumes it's in system PATH
PI_BIN=pi
# Directory where Pi session .jsonl files are located - default is ~/.pi/sessions
PI_SESSION_DIR=
# Working directory for Pi subprocess - default is current directory
PI_WORKDIR=
# Timeout for Telegram API long polling in seconds - default 25s
POLL_TIMEOUT_SECONDS=25
# Logging verbosity level (info, warn, error, debug) - default is info
LOG_LEVEL=info